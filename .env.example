# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Firecrawl — Brand Detection (required)
FIRECRAWL_API_KEY=your-firecrawl-api-key

# Gemini — AI Analysis (required for brand detection AI)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_TEXT_MODEL=gemini-2.5-flash

# ElevenLabs Voice Agent (set agent ID in src/App.tsx)
# Create an agent at https://elevenlabs.io/app/agents
# ELEVENLABS_API_KEY is only needed for signed URLs (optional for public agents)

# Stripe — Subscriptions (optional)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-webhook-secret

# Server
PORT=3001
